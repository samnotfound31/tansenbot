# ─────────────────────────────────────────────────────────────────────────────
# Tansen Bot — Environment Variables Template
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Spotify API (optional — for Spotify search features) ─────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ── Database path (IMPORTANT for Docker) ─────────────────────────────────────
# In Docker: point to the mounted volume so data persists across restarts.
# On local Windows dev: leave commented out (defaults to tansen_bot.db next to the script).
DATABASE_PATH=/data/tansen_bot.db

# ── Keep-alive server port ────────────────────────────────────────────────────
PORT=8080

# ── Genius API (optional — for lyrics fallback) ───────────────────────────────
GENIUS_ACCESS_TOKEN=your_genius_token_here
